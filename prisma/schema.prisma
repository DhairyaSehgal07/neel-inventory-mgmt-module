// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  Manager
  Supervisor
  Worker
}

enum FabricStatus {
  PACKED
  IN_USE
  CLOSED
  OPEN
  REJECTED
  TRADED
}

enum FabricHistoryAction {
  ASSIGN
  BALANCE_UPDATE
}

enum CompoundStatus {
  IN_USE
  PACKED
  ASSIGNED
  CONSUMED
  TRADED
  REJECTED
}

enum CompoundHistoryAction {
  ASSIGN
  BALANCE_UPDATE
  STATUS_CHANGE
}

enum CompoundMachinery {
  CAL_1
  CAL_2
  CAL_3
  CAL_4
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  mobileNumber String   @unique
  password     String
  role         Role     @default(Worker)
  permissions  String[] @default([])
  isActive     Boolean  @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  fabricHistories  FabricHistory[]
  compoundHistories CompoundHistory[]

  @@map("users")
}

model FabricType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_types")
}

model FabricStrength {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_strengths")
}

model FabricWidth {
  id        Int      @id @default(autoincrement())
  value     Float    // width value (e.g. in meters or inches)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_widths")
}

model Fabric {
  id               Int             @id @default(autoincrement())
  date             DateTime
  fabricDate       String
  fabricCode       String   @unique
  fabricTypeId     Int
  fabricStrengthId Int
  fabricWidthId       Int
  fabricLengthInitial Float
  fabricLengthCurrent Float
  fabricWidthInitial  Float
  fabricWidthCurrent  Float
  nameOfVendor        String
  gsmObserved      Float
  qrCode           String
  netWeight        Float
  gsmCalculated    Float
  status           FabricStatus?
  assignTo         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  fabricType     FabricType     @relation(fields: [fabricTypeId], references: [id])
  fabricStrength FabricStrength @relation(fields: [fabricStrengthId], references: [id])
  fabricWidth    FabricWidth    @relation(fields: [fabricWidthId], references: [id])
  history        FabricHistory[]
  locations      Location[]

  @@index([fabricWidthId, fabricStrengthId])
  @@map("fabrics")
}

model Location {
  id        Int      @id @default(autoincrement())
  fabricId  Int
  area      String
  floor     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabric Fabric @relation(fields: [fabricId], references: [id], onDelete: Cascade)

  @@map("locations")
}

model FabricHistory {
  id            Int                 @id @default(autoincrement())
  fabricId      Int
  actionType    FabricHistoryAction
  performedById Int
  createdAt     DateTime            @default(now())

  // Assign: who/what it was assigned to (before/after)
  assignToBefore String?
  assignToAfter  String?

  // Status before/after (for both assign and balance update)
  statusBefore String?
  statusAfter  String?

  // Balance update: length (m) before/after
  lengthBefore Float?
  lengthAfter  Float?

  fabric    Fabric @relation(fields: [fabricId], references: [id], onDelete: Cascade)
  performedBy User  @relation(fields: [performedById], references: [id])

  @@map("fabric_histories")
}

model RawMaterial {
  id           Int      @id @default(autoincrement())
  materialCode String
  date         DateTime
  createdBy    String
  material     String
  grade        String
  vendor       String
  quantity     Float
  units        String
  weight       Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("raw_materials")
}

model Compound {
  id     Int    @id @default(autoincrement())
  compoundCode String @unique
  /// Date of production
  dateOfProduction DateTime
  createdBy        String
  compoundName     String
  /// Batch / lot identifier (label)
  batch            String
  /// Number of batches used to compute total produced weight (total = batchCount × weightPerBatchKg)
  batchCount       Float
  /// Weight per batch (kg), weight produced
  weightPerBatchKg Float
  /// batchCount × weightPerBatchKg — set by application on create/update (same as DB-side generated total)
  totalWeightProducedKg Float
  /// Cumulative weight consumed (kg)
  weightConsumedKg      Float @default(0)
  /// totalWeightProducedKg − weightConsumedKg — maintain in app when consuming (for analytics/queries)
  weightRemainingKg     Float
  location              String
  status                CompoundStatus?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  history CompoundHistory[]

  @@map("compounds")
}

model CompoundHistory {
  id            Int                   @id @default(autoincrement())
  compoundId    Int
  actionType    CompoundHistoryAction
  performedById Int
  createdAt     DateTime              @default(now())

  // Assign (machinery step): qty, cal line, belt#
  assignedQtyKg    Float?
  assignedMachinery CompoundMachinery?
  beltNumber       String?

  assignToBefore String?
  assignToAfter  String?

  statusBefore CompoundStatus?
  statusAfter  CompoundStatus?

  // Balance: weight (kg) before/after consumption updates
  weightRemainingBeforeKg Float?
  weightRemainingAfterKg  Float?
  weightConsumedBeforeKg  Float?
  weightConsumedAfterKg   Float?

  compound    Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  performedBy User     @relation(fields: [performedById], references: [id])

  @@map("compound_histories")
}
