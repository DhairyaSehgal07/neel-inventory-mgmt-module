// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  Manager
  Supervisor
  Worker
}

enum FabricStatus {
  PACKED
  IN_USE
  CLOSED
  OPEN
  REJECTED
  TRADED
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  mobileNumber String   @unique
  password     String
  role         Role     @default(Worker)
  permissions  String[] @default([])
  isActive     Boolean  @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  issueFabrics IssueFabric[]

  @@map("users")
}

model FabricType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_types")
}

model FabricStrength {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_strengths")
}

model FabricWidth {
  id        Int      @id @default(autoincrement())
  value     Float    // width value (e.g. in meters or inches)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_widths")
}

model Fabric {
  id               Int             @id @default(autoincrement())
  date             DateTime
  fabricDate       String
  fabricCode       String   @unique
  fabricTypeId     Int
  fabricStrengthId Int
  fabricWidthId       Int
  fabricLengthInitial Float
  fabricLengthCurrent Float
  fabricWidthInitial  Float
  fabricWidthCurrent  Float
  nameOfVendor        String
  gsmObserved      Float
  qrCode           String
  netWeight        Float
  gsmCalculated    Float
  status           FabricStatus?
  assignTo         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  fabricType     FabricType     @relation(fields: [fabricTypeId], references: [id])
  fabricStrength FabricStrength @relation(fields: [fabricStrengthId], references: [id])
  fabricWidth    FabricWidth    @relation(fields: [fabricWidthId], references: [id])
  issueFabrics   IssueFabric[]

  @@map("fabrics")
}

model IssueFabric {
  id                    Int      @id @default(autoincrement())
  fabricId              Int
  lengthIssued          Float
  widthIssued           Float
  purpose               String
  createdById           Int
  createdAt             DateTime @default(now())
  // Snapshot of fabric stock before this issuance (client can compute remaining = before - issued)
  fabricLengthBeforeIssuance Float
  fabricWidthBeforeIssuance  Float
  fabricLengthRemaining      Float
  fabricWidthRemaining       Float

  fabric Fabric @relation(fields: [fabricId], references: [id])
  createdBy User @relation(fields: [createdById], references: [id])

  @@map("issue_fabrics")
}
