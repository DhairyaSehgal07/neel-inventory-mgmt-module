// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  Manager
  Supervisor
  Worker
}

enum FabricStatus {
  PACKED
  IN_USE
  CLOSED
  OPEN
  REJECTED
  TRADED
}

enum FabricHistoryAction {
  ASSIGN
  BALANCE_UPDATE
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  mobileNumber String   @unique
  password     String
  role         Role     @default(Worker)
  permissions  String[] @default([])
  isActive     Boolean  @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  fabricHistories FabricHistory[]

  @@map("users")
}

model FabricType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_types")
}

model FabricStrength {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_strengths")
}

model FabricWidth {
  id        Int      @id @default(autoincrement())
  value     Float    // width value (e.g. in meters or inches)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabrics Fabric[]

  @@map("fabric_widths")
}

model Fabric {
  id               Int             @id @default(autoincrement())
  date             DateTime
  fabricDate       String
  fabricCode       String   @unique
  fabricTypeId     Int
  fabricStrengthId Int
  fabricWidthId       Int
  fabricLengthInitial Float
  fabricLengthCurrent Float
  fabricWidthInitial  Float
  fabricWidthCurrent  Float
  nameOfVendor        String
  gsmObserved      Float
  qrCode           String
  netWeight        Float
  gsmCalculated    Float
  status           FabricStatus?
  assignTo         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  fabricType     FabricType     @relation(fields: [fabricTypeId], references: [id])
  fabricStrength FabricStrength @relation(fields: [fabricStrengthId], references: [id])
  fabricWidth    FabricWidth    @relation(fields: [fabricWidthId], references: [id])
  history        FabricHistory[]
  locations      Location[]

  @@index([fabricWidthId, fabricStrengthId])
  @@map("fabrics")
}

model Location {
  id        Int      @id @default(autoincrement())
  fabricId  Int
  area      String
  floor     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabric Fabric @relation(fields: [fabricId], references: [id], onDelete: Cascade)

  @@map("locations")
}

model FabricHistory {
  id            Int                 @id @default(autoincrement())
  fabricId      Int
  actionType    FabricHistoryAction
  performedById Int
  createdAt     DateTime            @default(now())

  // Assign: who/what it was assigned to (before/after)
  assignToBefore String?
  assignToAfter  String?

  // Status before/after (for both assign and balance update)
  statusBefore String?
  statusAfter  String?

  // Balance update: length (m) before/after
  lengthBefore Float?
  lengthAfter  Float?

  fabric    Fabric @relation(fields: [fabricId], references: [id], onDelete: Cascade)
  performedBy User  @relation(fields: [performedById], references: [id])

  @@map("fabric_histories")
}
